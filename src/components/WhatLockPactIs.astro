---
const isItems = [
  'Mutual accountability — your partner holds the key',
  'Real bypass detection — no secrets',
  'Free core product — no subscription',
  'Privacy-first — screen time data never leaves your device',
  'Built for iOS 17+ with native Screen Time API',
];

const isntItems = [
  "A solo willpower app you'll disable in 3 days",
  'A parental control tool',
  "A surveillance app — we can't see your apps",
  'A subscription trap',
  'Available on Android (yet)',
];
---

<section class="scroll-fade-up section-md px-6">
  <div class="max-w-[1200px] mx-auto">
    <p class="text-label uppercase text-center mb-3" style="color: var(--color-accent);">
      What LockPact Is
    </p>
    <h2 class="text-section-title text-center mb-10" style="color: var(--color-text-primary);">
      What it is — and what it isn't.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-7">
      <!-- What LockPact IS -->
      <div class="lp-card rounded-2xl p-8">
        <h3 class="text-card-title mb-5" style="color: var(--color-text-primary);">
          <span style="color: var(--color-unlocked);">&#10003;</span> What LockPact Is
        </h3>
        <ul class="space-y-3 list-none m-0 p-0">
          {isItems.map((item) => (
            <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <svg class="flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-unlocked)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- What LockPact ISN'T -->
      <div class="lp-card rounded-2xl p-8">
        <h3 class="text-card-title mb-5" style="color: var(--color-text-primary);">
          <span style="color: var(--color-locked);">&#10007;</span> What LockPact Isn't
        </h3>
        <ul class="space-y-3 list-none m-0 p-0">
          {isntItems.map((item) => (
            <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              <svg class="flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-locked)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
