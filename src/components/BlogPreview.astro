---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<section class="scroll-fade-up max-w-[1200px] mx-auto px-6 section-sm" id="blog-section">
  <p class="text-label uppercase text-center mb-3" style="color: var(--color-accent);">
    From the Blog
  </p>
  <h2 class="text-section-title text-center mb-10" style="color: var(--color-text-primary);">
    Latest from LockPact
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
    {posts.map((post) => (
      <BlogCard
        title={post.data.title}
        description={post.data.description}
        slug={post.slug}
        pubDate={post.data.pubDate}
      />
    ))}
  </div>
</section>
