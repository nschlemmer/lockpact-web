---
import AppStoreBadge from './AppStoreBadge.astro';
---

<section class="scroll-fade-up hero-glow section-lg px-6 text-center">
  <p class="text-label uppercase text-center mb-3" style="color: var(--color-accent);">
    Get Started
  </p>
  <h2 class="text-section-title text-center mb-4" style="color: var(--color-text-primary);">
    Ready to lock in?
  </h2>
  <p class="text-body-lg mb-8" style="color: var(--color-text-secondary);">
    Download LockPact. It's free. Your partner is waiting.
  </p>
  <AppStoreBadge size="large" />
</section>
