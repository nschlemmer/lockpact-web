---
const testimonials = [
  {
    quote: "I've deleted Instagram three times this month. LockPact is the first thing that actually stopped me \u2014 because my roommate would know.",
    source: 'Beta tester',
  },
  {
    quote: "We use it for no-phone dinner every night. The unlock request feature makes it real \u2014 you have to explain WHY you want your phone back.",
    source: 'Beta tester',
  },
  {
    quote: "I tried every solo screen time app. None of them stuck. Having my friend hold the key is completely different.",
    source: 'Beta tester',
  },
];
---

<section class="scroll-fade-up gradient-mesh py-16 sm:py-24 px-6">
  <div class="max-w-[1100px] mx-auto">
    <h2 class="text-[13px] font-bold uppercase tracking-widest text-center mb-10" style="color: var(--color-accent);">
      What Partners Are Saying
    </h2>
    <!-- Desktop: flex wrap, Mobile: horizontal scroll -->
    <div class="flex gap-6 justify-center flex-nowrap overflow-x-auto snap-x snap-mandatory md:flex-wrap md:overflow-x-visible pb-4 md:pb-0" style="-webkit-overflow-scrolling: touch;">
      {testimonials.map((t) => (
        <div
          class="lp-card flex-shrink-0 w-[280px] md:w-auto md:flex-1 md:min-w-[280px] max-w-[340px] rounded-2xl p-7 snap-center"
        >
          <div class="mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" style="fill: var(--color-accent-soft); stroke: none;">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>
          <p class="text-[15px] leading-relaxed italic mb-4 m-0" style="color: var(--color-text-primary);">
            "{t.quote}"
          </p>
          <p class="text-[13px] m-0" style="color: var(--color-text-tertiary);">
            &mdash; {t.source}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
