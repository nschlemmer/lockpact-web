---
interface Props {
  /** Which icon to render. */
  name: 'flame' | 'flame-fill' | 'sparkles';
  /** Tailwind classes for sizing — pass e.g. "w-8 h-8". */
  class?: string;
}

const { name, class: className = '' } = Astro.props;

// Each icon's stroke/fill mode determines whether to apply the gradient via
// `stroke="url(#flameHero)"` (outline icons) or `fill="url(#flameHero)"` (solid icon).
---

{name === 'flame' && (
  <svg
    class={className}
    viewBox="0 0 256 256"
    fill="none"
    stroke="url(#flameHero)"
    stroke-width="20"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M208,144c0-72-80-120-80-120S48,72,48,144a80,80,0,0,0,160,0Z"/>
    <path d="M88,184a40,40,0,0,0,80,0c0-40-40-64-40-64S88,144,88,184Z"/>
  </svg>
)}

{name === 'flame-fill' && (
  <svg
    class={className}
    viewBox="0 0 256 256"
    fill="url(#flameHero)"
    aria-hidden="true"
  >
    <path d="M173.79,51.48a221.25,221.25,0,0,0-41.67-34.34,8,8,0,0,0-8.24,0A221.25,221.25,0,0,0,82.21,51.48C54.59,80.48,40,112.47,40,144a88,88,0,0,0,176,0C216,112.47,201.41,80.48,173.79,51.48ZM96,184c0-27.67,22.53-47.28,32-54.3,9.48,7,32,26.63,32,54.3a32,32,0,0,1-64,0Z"/>
  </svg>
)}

{name === 'sparkles' && (
  <svg
    class={className}
    viewBox="0 0 24 24"
    fill="none"
    stroke="url(#flameHero)"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/>
    <path d="M20 2v4"/>
    <path d="M22 4h-4"/>
    <circle cx="4" cy="20" r="2" fill="url(#flameHero)" stroke="none"/>
  </svg>
)}
