---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate?: Date;
  readTime?: string;
}

const { title, description, slug, pubDate, readTime } = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
  : '';
---

<a
  href={`/blog/${slug}/`}
  class="lp-card block rounded-2xl p-6 transition-all group"
  style="border-left: 3px solid transparent;"
  onmouseover="this.style.borderLeftColor='var(--color-accent)'"
  onmouseout="this.style.borderLeftColor='transparent'"
>
  {(readTime || formattedDate) && (
    <div class="text-[11px] font-semibold mb-2.5" style="color: var(--color-accent);">
      {formattedDate}{formattedDate && readTime ? ' \u00B7 ' : ''}{readTime}
    </div>
  )}
  <h3
    class="text-base font-bold leading-snug mb-2 group-hover:opacity-80 transition-opacity"
    style="color: var(--color-text-primary);"
  >
    {title}
  </h3>
  <p class="text-sm leading-snug m-0" style="color: var(--color-text-secondary);">
    {description}
  </p>
</a>
