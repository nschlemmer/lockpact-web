---
const steps = [
  {
    num: '1',
    title: 'Pair Up',
    desc: 'Share a 6-digit code with your partner. A friend, a roommate, someone who gets it.',
    iconPath: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  },
  {
    num: '2',
    title: 'Lock Your Apps',
    desc: 'Each of you selects which apps to block. Instagram, TikTok, whatever pulls you in.',
    iconPath: 'M19 11H5M19 11a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2M19 11V9a2 2 0 00-2-2M7 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v2M9 7h6',
  },
  {
    num: '3',
    title: 'Stay Honest',
    desc: "Only your partner can approve an unlock. Bypass? They'll know.",
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];
---

<section class="max-w-[1100px] mx-auto px-6 py-12 md:py-16">
  <h2 class="text-[13px] font-bold uppercase tracking-widest text-center mb-10" style="color: var(--color-accent);">
    How It Works
  </h2>
  <div class="flex flex-wrap gap-6 justify-center">
    {steps.map((step) => (
      <div
        class="lp-card flex-1 min-w-[280px] max-w-[340px] rounded-2xl p-7 relative"
      >
        <div
          class="absolute -top-3 left-6 w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold text-white"
          style="background: var(--color-accent);"
        >
          {step.num}
        </div>
        <div class="mb-3">
          <svg width="32" height="32" viewBox="0 0 24 24" style="stroke: var(--color-accent); fill: none;" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d={step.iconPath} />
          </svg>
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-text-primary);">{step.title}</h3>
        <p class="text-[15px] leading-snug m-0" style="color: var(--color-text-secondary);">{step.desc}</p>
      </div>
    ))}
  </div>
</section>
