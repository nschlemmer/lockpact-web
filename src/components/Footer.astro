---

<footer class="border-t section-sm px-6 text-center" style="border-color: var(--color-card-border);">
  <div class="font-extrabold text-card-title mb-4" style="color: var(--color-text-primary);">
    <span style="color: var(--color-accent);">Lock</span>Pact
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-8 max-w-[640px] mx-auto text-left sm:text-center">
    <div>
      <h3 class="text-[11px] font-bold uppercase tracking-widest mb-3" style="color: var(--color-text-tertiary);">About</h3>
      <a href="/blog" class="block text-sm transition-opacity hover:opacity-80 mb-2" style="color: var(--color-text-secondary);">Blog</a>
    </div>
    <div>
      <h3 class="text-[11px] font-bold uppercase tracking-widest mb-3" style="color: var(--color-text-tertiary);">Help</h3>
      <a href="/support" class="block text-sm transition-opacity hover:opacity-80 mb-2" style="color: var(--color-text-secondary);">Support</a>
    </div>
    <div>
      <h3 class="text-[11px] font-bold uppercase tracking-widest mb-3" style="color: var(--color-text-tertiary);">Tip Jar</h3>
      <a href="/support-lockpact" class="block text-sm transition-opacity hover:opacity-80 mb-2" style="color: var(--color-text-secondary);">Support LockPact</a>
    </div>
    <div>
      <h3 class="text-[11px] font-bold uppercase tracking-widest mb-3" style="color: var(--color-text-tertiary);">Legal</h3>
      <a href="/privacy" class="block text-sm transition-opacity hover:opacity-80 mb-2" style="color: var(--color-text-secondary);">Privacy</a>
      <a href="/terms" class="block text-sm transition-opacity hover:opacity-80" style="color: var(--color-text-secondary);">Terms</a>
    </div>
  </div>
  <p class="text-caption m-0" style="color: var(--color-text-tertiary);">
    &copy; 2026 Rotate LLC
  </p>
</footer>
