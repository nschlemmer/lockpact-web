---
import { Image } from 'astro:assets';
import pairUp from '../assets/screenshots/pair-up.png';
import pickApps from '../assets/screenshots/pick-apps.png';
import proposePact from '../assets/screenshots/propose-pact.png';
import acceptPact from '../assets/screenshots/accept-pact.png';
import activity from '../assets/screenshots/activity.png';
import accountabilityAd from '../assets/screenshots/accountability-ad.png';

const steps = [
  { num: 1, tab: 'Pair',    title: 'Pair with someone you trust', desc: 'Share a 6-digit code. One minute to pair.',                                       img: pairUp,           alt: 'LockPact pairing screen showing a shared six-digit code' },
  { num: 2, tab: 'Choose',  title: 'Pick what to lock',            desc: 'Choose the apps. Your selection never leaves the device.',                         img: pickApps,         alt: 'iOS Family Activity Picker showing selected apps to block' },
  { num: 3, tab: 'Propose', title: 'Propose a pact',               desc: 'Pick a duration. Send it to your partner.',                                        img: proposePact,      alt: 'LockPact propose-pact screen with duration options' },
  { num: 4, tab: 'Accept',  title: 'Your partner accepts',         desc: 'Only they can approve. Only they can unlock.',                                     img: acceptPact,       alt: 'LockPact pact proposal received by the partner' },
  { num: 5, tab: 'Track',   title: 'See every move',               desc: 'Pacts, locks, and requests all show up in the Activity feed.',                     img: activity,         alt: 'LockPact activity feed with pact and lock events' },
  { num: 6, tab: 'Unlock',  title: 'Unlocking costs something',    desc: 'A brief accountability ad — or a one-time Willpower Waiver to skip ads forever.', img: accountabilityAd, alt: 'LockPact accountability ad with Willpower Waiver upsell' },
];
---

<section class="scroll-fade-up max-w-[1200px] mx-auto px-6 section-md" id="pact-showcase">
  <p class="text-label uppercase text-center mb-3" style="color: var(--color-accent);">
    The Pact Flow
  </p>
  <h2 class="text-section-title text-center mb-8" style="color: var(--color-text-primary);">
    From pair to pact in under a minute.
  </h2>

  {/* Tab strip — one-word labels */}
  <div
    role="tablist"
    aria-label="Pact flow steps"
    id="showcase-tablist"
    class="flex justify-center gap-2 sm:gap-3 mb-3 overflow-x-auto pb-1"
  >
    {steps.map((s, i) => (
      <button
        type="button"
        role="tab"
        id={`showcase-tab-${s.num}`}
        aria-controls={`showcase-slide-${s.num}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        tabindex={i === 0 ? 0 : -1}
        data-step={i}
        class="showcase-tab flex-shrink-0 text-caption font-bold px-4 py-2 rounded-full border transition-colors cursor-pointer whitespace-nowrap"
        style="border-color: var(--color-card-border); color: var(--color-text-secondary);"
      >
        {s.tab}
      </button>
    ))}
  </div>

  {/* Progress bar — width animates with active step */}
  <div
    class="max-w-[520px] mx-auto h-0.5 rounded-full overflow-hidden mb-6"
    style="background-color: var(--color-card-border);"
    aria-hidden="true"
  >
    <div
      id="showcase-progress"
      class="h-full transition-transform duration-300 ease-out"
      style="background-color: var(--color-accent); width: 100%; transform: scaleX(0.1667); transform-origin: left;"
    ></div>
  </div>

  {/* Caption — synced to active step */}
  <div
    class="text-center mb-6 min-h-[4.5rem]"
    aria-live="polite"
    id="showcase-caption"
  >
    <h3 class="text-card-title mb-1" style="color: var(--color-text-primary);" data-active-title>
      {steps[0].title}
    </h3>
    <p class="text-sm leading-relaxed m-0 max-w-[420px] mx-auto" style="color: var(--color-text-secondary);" data-active-desc>
      {steps[0].desc}
    </p>
  </div>

  {/* Persistent phone frame — bezel + glow do NOT move. Only the screenshot inside slides. */}
  <div class="relative mx-auto screenshot-glow" style="width: 280px; max-width: 100%; border-radius: 38px; background: #000; padding: 8px;">
    <div
      class="embla overflow-hidden"
      id="showcase-embla"
      role="region"
      aria-roledescription="carousel"
      aria-label="Pact flow steps"
      style="border-radius: 30px; background: #000;"
    >
      <div class="embla__container flex touch-pan-y">
        {steps.map((s, i) => (
          <div
            class="embla__slide"
            style="flex: 0 0 100%; min-width: 0;"
            role="group"
            aria-roledescription="slide"
            aria-label={`Step ${s.num} of 6: ${s.title}`}
            id={`showcase-slide-${s.num}`}
            data-step={i}
          >
            <Image
              src={s.img}
              alt={s.alt}
              class="w-full h-auto block showcase-image"
              loading={i === 0 ? 'eager' : 'lazy'}
              widths={[264, 528]}
              sizes="264px"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from 'embla-carousel';

  const root = document.getElementById('pact-showcase');
  const emblaNode = document.getElementById('showcase-embla');
  const tablist = document.getElementById('showcase-tablist');
  const progressBar = document.getElementById('showcase-progress');
  const activeTitle = document.querySelector<HTMLElement>('[data-active-title]');
  const activeDesc = document.querySelector<HTMLElement>('[data-active-desc]');

  if (root && emblaNode && tablist) {
    const steps = [
      { title: 'Pair with someone you trust', desc: 'Share a 6-digit code. One minute to pair.' },
      { title: 'Pick what to lock',            desc: 'Choose the apps. Your selection never leaves the device.' },
      { title: 'Propose a pact',               desc: 'Pick a duration. Send it to your partner.' },
      { title: 'Your partner accepts',         desc: 'Only they can approve. Only they can unlock.' },
      { title: 'See every move',               desc: 'Pacts, locks, and requests all show up in the Activity feed.' },
      { title: 'Unlocking costs something',    desc: 'A brief accountability ad — or a one-time Willpower Waiver to skip ads forever.' },
    ];

    const embla = EmblaCarousel(emblaNode as HTMLElement, {
      loop: false,
      align: 'center',
      skipSnaps: false,
      duration: 22,
    });

    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));

    function syncUI(index: number) {
      tabs.forEach((t, i) => {
        const active = i === index;
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.setAttribute('tabindex', active ? '0' : '-1');
        t.style.color = active ? 'var(--color-accent)' : 'var(--color-text-secondary)';
        t.style.borderColor = active ? 'var(--color-accent)' : 'var(--color-card-border)';
        t.style.backgroundColor = active ? 'var(--color-accent-soft)' : 'transparent';
      });
      if (progressBar) {
        progressBar.style.transform = `scaleX(${(index + 1) / steps.length})`;
      }
      if (activeTitle) activeTitle.textContent = steps[index].title;
      if (activeDesc) activeDesc.textContent = steps[index].desc;
    }

    embla.on('select', () => syncUI(embla.selectedScrollSnap()));

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => embla.scrollTo(i));
    });

    tablist.addEventListener('keydown', (e: KeyboardEvent) => {
      const current = embla.selectedScrollSnap();
      let next = current;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = Math.min(current + 1, steps.length - 1);
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = Math.max(current - 1, 0);
      else if (e.key === 'Home') next = 0;
      else if (e.key === 'End') next = steps.length - 1;
      else return;
      e.preventDefault();
      embla.scrollTo(next);
      tabs[next]?.focus();
    });

    // Preload + decode all images one viewport before section enters view.
    // By the time the user clicks a tab, bytes are fetched AND decoded — swaps are instant.
    const images = root.querySelectorAll<HTMLImageElement>('img.showcase-image');
    const preloader = new IntersectionObserver((entries) => {
      if (entries.some((e) => e.isIntersecting)) {
        images.forEach((img) => {
          img.loading = 'eager';
          img.decode().catch(() => {});
        });
        preloader.disconnect();
      }
    }, { rootMargin: '100% 0px' });
    preloader.observe(root);

    syncUI(0);
  }
</script>

<style>
  .showcase-tab:hover:not([aria-selected="true"]) {
    border-color: var(--color-text-tertiary) !important;
  }
  .showcase-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .embla__container {
    backface-visibility: hidden;
    touch-action: pan-y pinch-zoom;
  }
</style>
