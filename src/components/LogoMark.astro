---
// Inline the SVG as raw markup so `currentColor` and CSS custom properties work.
// (An `<img>` tag would not let CSS reach inside the SVG.)
import logoMarkRaw from '../assets/logo-mark.svg?raw';

interface Props {
  /** Pixel size — sets both width and height (mark is square post-viewBox-crop). */
  size?: number;
  /** Extra classes forwarded to the wrapper. */
  class?: string;
}

const { size = 28, class: className = '' } = Astro.props;
---

<span
  class={`inline-flex shrink-0 ${className}`}
  style={`width: ${size}px; height: ${size}px; color: var(--color-text-primary);`}
  set:html={logoMarkRaw}
/>
