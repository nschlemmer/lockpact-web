---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: object;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
