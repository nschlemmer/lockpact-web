---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PactShowcase from '../components/PactShowcase.astro';
import Differentiators from '../components/Differentiators.astro';
import WhatLockPactIs from '../components/WhatLockPactIs.astro';
import SocialProof from '../components/SocialProof.astro';
import FAQ from '../components/FAQ.astro';
import BlogPreview from '../components/BlogPreview.astro';
import DownloadCTA from '../components/DownloadCTA.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'LockPact',
  operatingSystem: 'iOS',
  applicationCategory: 'HealthApplication',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description: 'Mutual screen time accountability. Your partner holds the key.',
  url: 'https://lockpact.app',
  downloadUrl: 'https://apps.apple.com/app/lockpact/id6759302382',
  /* aggregateRating — add after 10+ real App Store reviews
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: 'XX',
  },
  */
};
---

<PageLayout
  title="LockPact — Screen Time Accountability with a Partner | Free iOS App"
  description="Lock your apps together. Only your partner can unlock them. LockPact is the free iOS app for mutual screen time accountability between friends, couples, and roommates."
  structuredData={structuredData}
>
  <Hero />
  <HowItWorks />
  <PactShowcase />
  <Differentiators />
  <WhatLockPactIs />
  <SocialProof />
  <FAQ />
  <BlogPreview />
  <DownloadCTA />
</PageLayout>
