---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import DownloadCTA from '../../components/DownloadCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<PageLayout
  title="LockPact Blog — Screen Time, Accountability, and What Actually Works"
  description="Articles about screen time, app blocking, accountability partners, and how to actually change your phone habits."
>
  <section class="max-w-[1100px] mx-auto px-6 py-16 md:py-24">
    <h1 class="text-3xl font-extrabold tracking-tight text-center mb-3" style="color: var(--color-text-primary);">
      Blog
    </h1>
    <p class="text-center mb-10" style="color: var(--color-text-secondary);">
      Screen time, accountability, and what actually works.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => {
        const wordCount = post.body.split(/\s+/).length;
        const readTime = `${Math.max(1, Math.ceil(wordCount / 250))} min read`;
        return (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            readTime={readTime}
          />
        );
      })}
    </div>
  </section>
  <DownloadCTA />
</PageLayout>
